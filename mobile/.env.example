# ─── Backend API URL ─────────────────────────────────
# Development (use your computer's local IP for physical devices)
EXPO_PUBLIC_API_URL=http://192.168.x.x:5000/api
# Production (deployed backend URL)
# EXPO_PUBLIC_API_URL=https://your-backend.onrender.com/api

# ─── Google Maps / Places API Key ────────────────────
EXPO_PUBLIC_GOOGLE_API_KEY=your-google-api-key

# ─── OpenWeatherMap API Key ──────────────────────────
EXPO_PUBLIC_OPENWEATHER_KEY=your-openweather-key

# ─── LocationIQ API Key ─────────────────────────────
EXPO_PUBLIC_LOCATIONIQ_KEY=your-locationiq-key
